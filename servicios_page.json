      "_type": "htmlBlock",
      "html": "<table style=\"border-collapse: collapse; width: 100%; height: 367px;\"> <tbody> <tr style=\"height: 23px;\"> <td style=\"width: 25%; height: 23px; text-align: center;\"> <h3><strong>SERVICIO</strong></h3> </td> <td style=\"width: 25%; height: 23px; text-align: center;\"> <h3><strong>OPCIÓN 1</strong></h3> </td> <td style=\"width: 25%; height: 23px; text-align: center;\"> <h3><strong>OPCIÓN 2</strong></h3> </td> <td style=\"width: 25%; height: 23px; text-align: center;\"> <h3><strong>OPCIÓN 3</strong></h3> </td> </tr> <tr style=\"height: 63px;\"> <td style=\"width: 25%; height: 63px; text-align: center;\"><strong><a href=\"/plan-entrenamiento-online-o-mixto/\" target=\"_blank\" rel=\"noopener noreferrer\" data-rich-text-format-boundary=\"true\">Planes de entrenamiento individualizados</a></strong></td> <td style=\"width: 25%; height: 63px; text-align: center;\">Online: 60€</td> <td style=\"width: 25%; height: 63px; text-align: center;\">Mixto: 90€</td> <td style=\"width: 25%; height: 63px; text-align: center;\">A medida (a consultar)</td> </tr> <tr style=\"height: 63px;\"> <td style=\"width: 25%; height: 63px; text-align: center;\"><strong><a href=\"/planes-entrenamiento-en-grupo/\" target=\"_blank\" rel=\"noopener noreferrer\" data-rich-text-format-boundary=\"true\">Planes de entrenamiento en grupo</a></strong></td> <td style=\"width: 25%; height: 63px; text-align: center;\">5 a 10 pers: 50€</td> <td style=\"width: 25%; height: 63px; text-align: center;\">11 a 20 pers: 40€</td> <td style=\"width: 25%; height: 63px; text-align: center;\">21 o más pers: 35€</td> </tr> <tr style=\"height: 43px;\"> <td style=\"width: 25%; height: 43px; text-align: center;\"><strong><a href=\"/clases-presenciales/\" target=\"_blank\" rel=\"noopener noreferrer\" data-rich-text-format-boundary=\"true\">Clases presenciales</a></strong></td> <td style=\"width: 25%; height: 43px; text-align: center;\">Indiv: 60€ (tráete un acompañante)</td> <td style=\"width: 25%; height: 43px; text-align: center;\">5 a 10 pers: 25€</td> <td style=\"width: 25%; height: 43px; text-align: center;\">11 o más pers: 20€</td> </tr> <tr style=\"height: 23px;\"> <td style=\"width: 25%; height: 23px; text-align: center;\"><a href=\"/informe-tecnico-y-antropometria/\" target=\"_blank\" rel=\"noopener noreferrer\"><strong>Informe técnico</strong></a></td> <td style=\"height: 23px; text-align: center;\" colspan=\"3\">60€</td> </tr> <tr style=\"height: 23px;\"> <td style=\"width: 25%; text-align: center; height: 23px;\"><a href=\"/informe-tecnico-y-antropometria/\" target=\"_blank\" rel=\"noopener noreferrer\"><strong>Antropometría</strong></a></td> <td style=\"width: 25%; text-align: center; height: 23px;\" colspan=\"3\">60€</td> </tr> <tr style=\"height: 23px;\"> <td style=\"width: 25%; height: 23px; text-align: center;\"><strong><a href=\"/webinars/\" target=\"_blank\" rel=\"noopener noreferrer\" data-rich-text-format-boundary=\"true\">Plan entrenamiento de fuerza</a></strong></td> <td style=\"width: 25%; height: 23px; text-align: center;\" colspan=\"3\">30€</td> </tr> <tr style=\"height: 43px;\"> <td style=\"width: 25%; height: 43px; text-align: center;\"><strong><a href=\"/clinics-presenciales/\" target=\"_blank\" rel=\"noopener noreferrer\" data-rich-text-format-boundary=\"true\">Clínic presencial</a></strong></td> <td style=\"width: 25%; height: 43px; text-align: center;\" colspan=\"3\">A consultar</td> </tr> <tr style=\"height: 63px;\"> <td style=\"width: 25%; height: 63px; text-align: center;\"><strong><a href=\"/asesoramiento-entrenamiento/\" target=\"_blank\" rel=\"noopener noreferrer\" data-rich-text-format-boundary=\"true\">Asesoramiento sobre entrenamiento</a></strong></td> <td style=\"width: 25%; height: 63px; text-align: center;\">Videoconf: 60€/hora</td> <td style=\"width: 25%; height: 63px; text-align: center;\">Presencial: 100€/hora</td> <td style=\"width: 25%; height: 63px; text-align: center;\">Clínics: a consultar</td> </tr> </tbody> </table>"
